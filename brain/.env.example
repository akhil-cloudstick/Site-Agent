# SiteAgent Brain — environment. Copy to brain/.env and fill in.
# All values are SERVER-SIDE secrets (no NEXT_PUBLIC_ prefix) → never sent to the browser.
# Read only via src/config/env.ts (the single audited config seam).

# Required — Postgres connection (local dev → Neon in prod; swap is config-only).
DATABASE_URL=postgresql://siteagent:siteagent_dev_pw@localhost:5432/siteagent_dev

# Required — Payload signing secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))").
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Optional — Gemini API key for the content agent (wired in a later slice-1 task).
GEMINI_API_KEY=
